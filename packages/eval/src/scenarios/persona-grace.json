{
  "id": "persona-grace",
  "agentId": "ontofelia",
  "userId": "grace",
  "turns": [
    { "kind": "assert", "id": "g-t1", "text": "My name is Grace.",
      "fact": { "s": "User", "p": "name", "o": "Grace", "sType": "Person", "oType": "literal" }, "entities": ["grace"] },
    { "kind": "probe", "id": "g-p0a", "category": "H0",
      "query": "I just told you my name. What is it?",
      "entities": ["Grace"],
      "gold": { "type": "exact", "value": "Grace" } },

    { "kind": "assert", "id": "g-t2", "text": "My seat row is 14.",
      "fact": { "s": "Grace", "p": "seatRow", "o": "14", "sType": "Person", "oType": "literal" }, "entities": ["Grace"] },
    { "kind": "probe", "id": "g-p0b", "category": "H0",
      "query": "A moment ago I gave my seat row in this chat. What is it?",
      "entities": ["Grace"],
      "gold": { "type": "exact", "value": "14" } },

    { "kind": "assert", "id": "g-t3", "text": "My building gate is West.",
      "fact": { "s": "Grace", "p": "gate", "o": "West", "sType": "Person", "oType": "literal" }, "entities": ["Grace"] },
    { "kind": "probe", "id": "g-p0c", "category": "H0",
      "query": "Which building gate did I just mention in this conversation?",
      "entities": ["Grace"],
      "gold": { "type": "exact", "value": "West" } },

    { "kind": "assert", "id": "g-t4", "text": "I lead the Quasar team.",
      "fact": { "s": "Grace", "p": "manages", "o": "Quasar", "sType": "Person", "oType": "Organization" }, "entities": ["Grace"] },
    { "kind": "assert", "id": "g-t5", "text": "The Quasar team uses Terraform.",
      "fact": { "s": "Quasar", "p": "usesTool", "o": "Terraform", "sType": "Organization", "oType": "Concept" }, "entities": ["Quasar"] },
    { "kind": "assert", "id": "g-t6", "text": "The Quasar team uses Vault.",
      "fact": { "s": "Quasar", "p": "usesTool", "o": "Vault", "sType": "Organization", "oType": "Concept" }, "entities": ["Quasar"] },

    { "kind": "assert", "id": "g-t7", "text": "I am allergic to peanuts.",
      "fact": { "s": "Grace", "p": "allergicTo", "o": "peanuts", "sType": "Person", "oType": "Concept" }, "entities": ["Grace"] },
    { "kind": "assert", "id": "g-t8", "text": "I am allergic to shellfish.",
      "fact": { "s": "Grace", "p": "allergicTo", "o": "shellfish", "sType": "Person", "oType": "Concept" }, "entities": ["Grace"] },
    { "kind": "assert", "id": "g-t9", "text": "I am allergic to latex.",
      "fact": { "s": "Grace", "p": "allergicTo", "o": "latex", "sType": "Person", "oType": "Concept" }, "entities": ["Grace"] },

    { "kind": "assert", "id": "g-t10", "text": "My role is product lead.",
      "fact": { "s": "Grace", "p": "hasRole", "o": "product lead", "sType": "Person", "oType": "literal" }, "entities": ["Grace"] },
    { "kind": "assert", "id": "g-t11", "text": "I was born in Dublin.",
      "fact": { "s": "Grace", "p": "bornIn", "o": "Dublin", "sType": "Person", "oType": "Place" }, "entities": ["Grace"] },

    { "kind": "pad", "count": 32 },

    { "kind": "probe", "id": "g-p1a", "category": "H1",
      "query": "Which team do I lead?",
      "paraphrases": ["What team do I manage?"],
      "entities": ["Grace"],
      "gold": { "type": "exact", "value": "Quasar" } },
    { "kind": "probe", "id": "g-p1b", "category": "H1",
      "query": "Where was I born?",
      "entities": ["Grace"],
      "gold": { "type": "exact", "value": "Dublin" } },
    { "kind": "probe", "id": "g-p1c", "category": "H1",
      "query": "What is my seat row?",
      "entities": ["Grace"],
      "gold": { "type": "exact", "value": "14" } },

    { "kind": "probe", "id": "g-p2a", "category": "H2",
      "query": "What am I allergic to?",
      "paraphrases": ["List all my allergies."],
      "entities": ["Grace"],
      "gold": { "type": "set", "value": ["peanuts", "shellfish", "latex"],
        "candidates": ["peanuts", "shellfish", "latex", "pollen", "gluten", "dairy", "dust"] } },
    { "kind": "probe", "id": "g-p2mh", "category": "H2",
      "query": "Which tools does the team I lead use?",
      "paraphrases": ["What software does my team rely on?"],
      "entities": ["Grace"],
      "hops": ["manages", "usesTool"],
      "gold": { "type": "set", "value": ["Terraform", "Vault"],
        "candidates": ["Terraform", "Vault", "Consul", "Ansible", "Pulumi", "Nomad"] } },
    { "kind": "probe", "id": "g-p2b", "category": "H2",
      "query": "Enumerate every allergy of mine.",
      "entities": ["Grace"],
      "gold": { "type": "set", "value": ["peanuts", "shellfish", "latex"],
        "candidates": ["peanuts", "shellfish", "latex", "pollen", "gluten", "dairy", "dust"] } },

    { "kind": "probe", "id": "g-p4a", "category": "H4",
      "query": "Which message and time did you learn that I lead Quasar? Cite source id and timestamp.",
      "entities": ["Grace"],
      "gold": { "type": "provenance", "value": "Quasar", "sourceTurnId": "g-t4", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "g-p4b", "category": "H4",
      "query": "Where did the fact that I was born in Dublin come from? Give message id and time.",
      "entities": ["Grace"],
      "gold": { "type": "provenance", "value": "Dublin", "sourceTurnId": "g-t11", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "g-p4c", "category": "H4",
      "query": "What is the source of my seat row fact? Cite the message id and time.",
      "entities": ["Grace"],
      "gold": { "type": "provenance", "value": "14", "sourceTurnId": "g-t2", "tsToleranceSec": 5 } },

    { "kind": "mutate", "id": "g-t12", "text": "Actually my role is now director of product.",
      "fact": { "s": "Grace", "p": "hasRole", "o": "director of product", "sType": "Person", "oType": "literal" }, "supersedes": "hasRole", "entities": ["Grace"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "g-p3a", "category": "H3",
      "query": "What is my current role?",
      "entities": ["Grace"],
      "gold": { "type": "value+flag", "value": "director", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "g-t13", "text": "Actually the team I lead is now Pulsar, not Quasar.",
      "fact": { "s": "Grace", "p": "manages", "o": "Pulsar", "sType": "Person", "oType": "Organization" }, "supersedes": "manages", "entities": ["Grace"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "g-p3b", "category": "H3",
      "query": "Which team do I lead now?",
      "entities": ["Grace"],
      "gold": { "type": "value+flag", "value": "Pulsar", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "g-t14", "text": "Actually my gate changed to East.",
      "fact": { "s": "Grace", "p": "gate", "o": "East", "sType": "Person", "oType": "literal" }, "supersedes": "gate", "entities": ["Grace"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "g-p3c", "category": "H3",
      "query": "What is my building gate now?",
      "entities": ["Grace"],
      "gold": { "type": "value+flag", "value": "East", "expectConflictFlag": true } },

    { "kind": "assert", "id": "g-t15", "text": "I am 28 years old.",
      "fact": { "s": "Grace", "p": "hasAge", "o": "28", "sType": "Person", "oType": "literal" }, "entities": ["Grace"] },
    { "kind": "assert", "id": "g-t16", "text": "I also said I am 71 years old.",
      "fact": { "s": "Grace", "p": "hasAge", "o": "71", "sType": "Person", "oType": "literal" }, "entities": ["Grace"] },
    { "kind": "pad", "count": 14 },

    { "kind": "probe", "id": "g-p5a", "category": "H5",
      "query": "I said I am both 28 and 71. A person has exactly one age. Consistent or a violation?",
      "entities": ["Grace"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "g-p5b", "category": "H5",
      "query": "If age is single-valued, can my two stated ages both hold? Flag the violation.",
      "entities": ["Grace"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "g-p5c", "category": "H5",
      "query": "Is there a functional-property violation in the two ages I gave?",
      "entities": ["Grace"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },

    { "kind": "retract", "id": "g-t17", "text": "Forget which team I lead.",
      "fact": { "s": "Grace", "p": "manages", "o": "Pulsar", "sType": "Person", "oType": "Organization" }, "entities": ["Grace"] },
    { "kind": "retract", "id": "g-t18", "text": "Also forget my building gate.",
      "fact": { "s": "Grace", "p": "gate", "o": "East", "sType": "Person", "oType": "literal" }, "entities": ["Grace"] },
    { "kind": "pad", "count": 14 },

    { "kind": "probe", "id": "g-p6a", "category": "H6",
      "query": "Which team do I lead?",
      "entities": ["Grace"],
      "gold": { "type": "leakage", "mustNotContain": ["Pulsar", "Quasar"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "g-p6b", "category": "H6",
      "query": "What is my building gate?",
      "entities": ["Grace"],
      "gold": { "type": "leakage", "mustNotContain": ["East", "West"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "g-p6n1", "category": "H6",
      "query": "Where was I born? (neighbour that must survive the forgetting)",
      "entities": ["Grace"],
      "gold": { "type": "leakage", "mustNotContain": ["Pulsar", "Quasar", "East"], "neighborsMustStay": ["Dublin"] } },
    { "kind": "probe", "id": "g-p6n2", "category": "H6",
      "query": "What am I allergic to? (neighbours that must survive forgetting)",
      "entities": ["Grace"],
      "gold": { "type": "leakage", "mustNotContain": ["Pulsar", "East"], "neighborsMustStay": ["peanuts", "shellfish", "latex"] } }
  ]
}
