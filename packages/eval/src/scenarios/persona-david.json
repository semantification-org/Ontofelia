{
  "id": "persona-david",
  "agentId": "ontofelia",
  "userId": "david",
  "turns": [
    { "kind": "assert", "id": "d-t0", "text": "My phone number ends in 4471.",
      "fact": { "s": "David", "p": "phoneSuffix", "o": "4471", "sType": "Person", "oType": "literal" }, "entities": ["David"] },

    { "kind": "probe", "id": "d-p0", "category": "H0",
      "query": "Right now in this chat I gave you the last four digits of my phone. What were they?",
      "entities": ["David"],
      "gold": { "type": "exact", "value": "4471" } },

    { "kind": "assert", "id": "d-t1", "text": "My name is David.",
      "fact": { "s": "User", "p": "name", "o": "David", "sType": "Person", "oType": "literal" }, "entities": ["david"] },
    { "kind": "probe", "id": "d-p0b", "category": "H0",
      "query": "I just said my name in this chat. What is it?",
      "entities": ["David"],
      "gold": { "type": "exact", "value": "David" } },

    { "kind": "assert", "id": "d-t1b", "text": "My office floor is 7.",
      "fact": { "s": "David", "p": "officeFloor", "o": "7", "sType": "Person", "oType": "literal" }, "entities": ["David"] },
    { "kind": "probe", "id": "d-p0c", "category": "H0",
      "query": "A second ago I told you my office floor. What number is it?",
      "entities": ["David"],
      "gold": { "type": "exact", "value": "7" } },

    { "kind": "assert", "id": "d-t2", "text": "I work at the company Northwind.",
      "fact": { "s": "David", "p": "worksAt", "o": "Northwind", "sType": "Person", "oType": "Organization" }, "entities": ["David"] },
    { "kind": "assert", "id": "d-t3", "text": "Northwind runs the project Aurora.",
      "fact": { "s": "Northwind", "p": "runs", "o": "Aurora", "sType": "Organization", "oType": "Concept" }, "entities": ["Northwind"] },
    { "kind": "assert", "id": "d-t4", "text": "The Aurora project uses Kafka.",
      "fact": { "s": "Aurora", "p": "usesTool", "o": "Kafka", "sType": "Concept", "oType": "Concept" }, "entities": ["Aurora"] },
    { "kind": "assert", "id": "d-t5", "text": "The Aurora project uses Spark.",
      "fact": { "s": "Aurora", "p": "usesTool", "o": "Spark", "sType": "Concept", "oType": "Concept" }, "entities": ["Aurora"] },

    { "kind": "assert", "id": "d-t6", "text": "I speak French.",
      "fact": { "s": "David", "p": "speaks", "o": "French", "sType": "Person", "oType": "Concept" }, "entities": ["David"] },
    { "kind": "assert", "id": "d-t7", "text": "I speak Arabic.",
      "fact": { "s": "David", "p": "speaks", "o": "Arabic", "sType": "Person", "oType": "Concept" }, "entities": ["David"] },
    { "kind": "assert", "id": "d-t8", "text": "I speak Japanese.",
      "fact": { "s": "David", "p": "speaks", "o": "Japanese", "sType": "Person", "oType": "Concept" }, "entities": ["David"] },
    { "kind": "assert", "id": "d-t9", "text": "I speak Dutch.",
      "fact": { "s": "David", "p": "speaks", "o": "Dutch", "sType": "Person", "oType": "Concept" }, "entities": ["David"] },

    { "kind": "assert", "id": "d-t10", "text": "My job title is staff engineer.",
      "fact": { "s": "David", "p": "hasTitle", "o": "staff engineer", "sType": "Person", "oType": "literal" }, "entities": ["David"] },
    { "kind": "assert", "id": "d-t11", "text": "I live in Toronto.",
      "fact": { "s": "David", "p": "livesIn", "o": "Toronto", "sType": "Person", "oType": "Place" }, "entities": ["David"] },

    { "kind": "pad", "count": 40 },

    { "kind": "probe", "id": "d-p1a", "category": "H1",
      "query": "Which company do I work at?",
      "paraphrases": ["Who is my employer?"],
      "entities": ["David"],
      "gold": { "type": "exact", "value": "Northwind" } },
    { "kind": "probe", "id": "d-p1b", "category": "H1",
      "query": "What city do I live in?",
      "entities": ["David"],
      "gold": { "type": "exact", "value": "Toronto" } },

    { "kind": "probe", "id": "d-p2a", "category": "H2",
      "query": "Which languages do I speak?",
      "paraphrases": ["List every language I know."],
      "entities": ["David"],
      "gold": { "type": "set", "value": ["French", "Arabic", "Japanese", "Dutch"],
        "candidates": ["French", "Arabic", "Japanese", "Dutch", "German", "Spanish", "Korean", "Hindi"] } },

    { "kind": "probe", "id": "d-p2-3hop", "category": "H2",
      "query": "Which tools do the projects run by the company I work at use?",
      "paraphrases": ["Through my employer and its project, what technologies are used?"],
      "entities": ["David"],
      "hops": ["worksAt", "runs", "usesTool"],
      "gold": { "type": "set", "value": ["Kafka", "Spark"],
        "candidates": ["Kafka", "Spark", "Flink", "Hadoop", "Storm", "Beam"] } },

    { "kind": "probe", "id": "d-p4a", "category": "H4",
      "query": "From which message and at what time did you learn I work at Northwind? Cite the source message id and timestamp.",
      "entities": ["David"],
      "gold": { "type": "provenance", "value": "Northwind", "sourceTurnId": "d-t2", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "d-p4b", "category": "H4",
      "query": "What is the source of the fact that I live in Toronto? Give the message id and time.",
      "entities": ["David"],
      "gold": { "type": "provenance", "value": "Toronto", "sourceTurnId": "d-t11", "tsToleranceSec": 5 } },

    { "kind": "mutate", "id": "d-t12", "text": "Actually my title is now principal engineer.",
      "fact": { "s": "David", "p": "hasTitle", "o": "principal engineer", "sType": "Person", "oType": "literal" }, "supersedes": "hasTitle", "entities": ["David"] },
    { "kind": "pad", "count": 18 },

    { "kind": "probe", "id": "d-p3a", "category": "H3",
      "query": "What is my current job title?",
      "entities": ["David"],
      "gold": { "type": "value+flag", "value": "principal", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "d-t13", "text": "Actually I moved; I now live in Vancouver.",
      "fact": { "s": "David", "p": "livesIn", "o": "Vancouver", "sType": "Person", "oType": "Place" }, "supersedes": "livesIn", "entities": ["David"] },
    { "kind": "pad", "count": 18 },

    { "kind": "probe", "id": "d-p3b", "category": "H3",
      "query": "Where do I live now?",
      "entities": ["David"],
      "gold": { "type": "value+flag", "value": "Vancouver", "expectConflictFlag": true } },

    { "kind": "assert", "id": "d-t14", "text": "My shoe size is 9.",
      "fact": { "s": "David", "p": "shoeSize", "o": "9", "sType": "Person", "oType": "literal" }, "entities": ["David"] },
    { "kind": "assert", "id": "d-t15", "text": "I also said my shoe size is 12.",
      "fact": { "s": "David", "p": "shoeSize", "o": "12", "sType": "Person", "oType": "literal" }, "entities": ["David"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "d-p5a", "category": "H5",
      "query": "I told you my shoe size is both 9 and 12. One foot, one size. Is that consistent or is there a violation?",
      "entities": ["David"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "d-p5b", "category": "H5",
      "query": "Shoe size is a single-valued attribute. Can both of my stated sizes hold at once? Flag any violation.",
      "entities": ["David"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },

    { "kind": "retract", "id": "d-t16", "text": "Forget my current title entirely.",
      "fact": { "s": "David", "p": "hasTitle", "o": "principal engineer", "sType": "Person", "oType": "literal" }, "entities": ["David"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "d-p6a", "category": "H6",
      "query": "What is my job title?",
      "entities": ["David"],
      "gold": { "type": "leakage", "mustNotContain": ["principal engineer", "staff engineer"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "d-p6n", "category": "H6",
      "query": "Which company do I work at? (neighbour fact that must survive the title forgetting)",
      "entities": ["David"],
      "gold": { "type": "leakage", "mustNotContain": ["principal engineer", "staff engineer"], "neighborsMustStay": ["Northwind"] } }
  ]
}
