{
  "id": "persona-carol",
  "agentId": "ontofelia",
  "userId": "carol",
  "turns": [
    { "kind": "assert", "id": "c-t3", "text": "My pet is a dog named Pixel.",
      "fact": { "s": "Carol", "p": "hasPet", "o": "Pixel", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },

    { "kind": "probe", "id": "c-p0a", "category": "H0",
      "query": "A second ago I mentioned my pet's name. What is it?",
      "entities": ["Carol"],
      "gold": { "type": "exact", "value": "Pixel" } },

    { "kind": "assert", "id": "c-t1", "text": "My name is Carol.",
      "fact": { "s": "User", "p": "name", "o": "Carol", "sType": "Person", "oType": "literal" }, "entities": ["carol"] },
    { "kind": "assert", "id": "c-t2", "text": "I work on the Vesta project.",
      "fact": { "s": "Carol", "p": "worksOn", "o": "Vesta", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t4", "text": "I use the tool Git.",
      "fact": { "s": "Carol", "p": "uses", "o": "Git", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t5", "text": "I also use Docker.",
      "fact": { "s": "Carol", "p": "uses", "o": "Docker", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t6", "text": "I also use Kubernetes.",
      "fact": { "s": "Carol", "p": "uses", "o": "Kubernetes", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t7", "text": "My hobbies are climbing.",
      "fact": { "s": "Carol", "p": "hasHobby", "o": "climbing", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t8", "text": "Another hobby of mine is painting.",
      "fact": { "s": "Carol", "p": "hasHobby", "o": "painting", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t9", "text": "My birthplace is Lisbon.",
      "fact": { "s": "Carol", "p": "bornIn", "o": "Lisbon", "sType": "Person", "oType": "Place" }, "entities": ["Carol"] },

    { "kind": "assert", "id": "c-t2b", "text": "The Vesta project uses Terraform.",
      "fact": { "s": "Vesta", "p": "usesTool", "o": "Terraform", "sType": "Concept", "oType": "Concept" }, "entities": ["Vesta"] },
    { "kind": "assert", "id": "c-t2c", "text": "The Vesta project uses Postgres.",
      "fact": { "s": "Vesta", "p": "usesTool", "o": "Postgres", "sType": "Concept", "oType": "Concept" }, "entities": ["Vesta"] },

    { "kind": "pad", "count": 25 },

    { "kind": "probe", "id": "c-p1a", "category": "H1",
      "query": "What project do I work on?",
      "paraphrases": ["Which project am I on?"],
      "entities": ["Carol"],
      "gold": { "type": "exact", "value": "Vesta" } },
    { "kind": "probe", "id": "c-p1b", "category": "H1",
      "query": "Where was I born?",
      "entities": ["Carol"],
      "gold": { "type": "exact", "value": "Lisbon" } },

    { "kind": "probe", "id": "c-p2a", "category": "H2",
      "query": "Which tools do I use?",
      "paraphrases": ["List my tools."],
      "entities": ["Carol"],
      "gold": { "type": "set", "value": ["Git", "Docker", "Kubernetes"],
        "candidates": ["Git", "Docker", "Kubernetes", "Mercurial", "Podman", "Nomad", "Terraform"] } },
    { "kind": "probe", "id": "c-p2b", "category": "H2",
      "query": "What are my hobbies?",
      "entities": ["Carol"],
      "gold": { "type": "set", "value": ["climbing", "painting"],
        "candidates": ["climbing", "painting", "running", "cooking", "gaming", "sailing"] } },

    { "kind": "probe", "id": "c-p2mh", "category": "H2",
      "query": "Which tools do the projects I work on use?",
      "paraphrases": ["What technologies does my project depend on?"],
      "entities": ["Carol"],
      "hops": ["worksOn", "usesTool"],
      "gold": { "type": "set", "value": ["Terraform", "Postgres"],
        "candidates": ["Terraform", "Postgres", "Git", "Docker", "Kubernetes", "MySQL", "Redis"] } },

    { "kind": "probe", "id": "c-p4a", "category": "H4",
      "query": "Which message did you learn my birthplace from, and when? Cite the source message id and timestamp.",
      "entities": ["Carol"],
      "gold": { "type": "provenance", "value": "Lisbon", "sourceTurnId": "c-t9", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "c-p4b", "category": "H4",
      "query": "What is the source of the fact that I use Kubernetes? Give the message id and time.",
      "entities": ["Carol"],
      "gold": { "type": "provenance", "value": "Kubernetes", "sourceTurnId": "c-t6", "tsToleranceSec": 5 } },

    { "kind": "mutate", "id": "c-t10", "text": "Actually my main project is now Ceres, not Vesta.",
      "fact": { "s": "Carol", "p": "worksOn", "o": "Ceres", "sType": "Person", "oType": "Concept" }, "supersedes": "worksOn", "entities": ["Carol"] },
    { "kind": "pad", "count": 15 },

    { "kind": "probe", "id": "c-p3a", "category": "H3",
      "query": "What is my current main project?",
      "entities": ["Carol"],
      "gold": { "type": "value+flag", "value": "Ceres", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "c-t11", "text": "Actually my pet's name is now Byte, I renamed her.",
      "fact": { "s": "Carol", "p": "hasPet", "o": "Byte", "sType": "Person", "oType": "Concept" }, "supersedes": "hasPet", "entities": ["Carol"] },
    { "kind": "pad", "count": 15 },

    { "kind": "probe", "id": "c-p3b", "category": "H3",
      "query": "What is my pet called now?",
      "entities": ["Carol"],
      "gold": { "type": "value+flag", "value": "Byte", "expectConflictFlag": true } },

    { "kind": "assert", "id": "c-t12", "text": "I was born in 1990.",
      "fact": { "s": "Carol", "p": "bornInYear", "o": "1990", "sType": "Person", "oType": "literal" }, "entities": ["Carol"] },
    { "kind": "assert", "id": "c-t13", "text": "I also claim I was born in 2005.",
      "fact": { "s": "Carol", "p": "bornInYear", "o": "2005", "sType": "Person", "oType": "literal" }, "entities": ["Carol"] },
    { "kind": "pad", "count": 15 },

    { "kind": "probe", "id": "c-p5a", "category": "H5",
      "query": "I said I was born in both 1990 and 2005. A person has exactly one birth year. Is that consistent, or is there a violation?",
      "entities": ["Carol"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "c-p5d", "category": "H5",
      "query": "If a single functional attribute must have one value, can I have two different birth years? Flag any violation.",
      "entities": ["Carol"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },

    { "kind": "retract", "id": "c-t14", "text": "Forget that I work on Ceres.",
      "fact": { "s": "Carol", "p": "worksOn", "o": "Ceres", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "retract", "id": "c-t15", "text": "Also forget that my pet is named Byte.",
      "fact": { "s": "Carol", "p": "hasPet", "o": "Byte", "sType": "Person", "oType": "Concept" }, "entities": ["Carol"] },
    { "kind": "pad", "count": 15 },

    { "kind": "probe", "id": "c-p6a", "category": "H6",
      "query": "What project do I work on?",
      "entities": ["Carol"],
      "gold": { "type": "leakage", "mustNotContain": ["Ceres", "Vesta"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "c-p6b", "category": "H6",
      "query": "What is my pet's name?",
      "entities": ["Carol"],
      "gold": { "type": "leakage", "mustNotContain": ["Byte", "Pixel"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "c-p6n", "category": "H6",
      "query": "Where was I born? (a neighbour fact that must survive the forgetting)",
      "entities": ["Carol"],
      "gold": { "type": "leakage", "mustNotContain": ["Ceres", "Vesta", "Byte"], "neighborsMustStay": ["Lisbon"] } }
  ]
}
