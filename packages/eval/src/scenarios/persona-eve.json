{
  "id": "persona-eve",
  "agentId": "ontofelia",
  "userId": "eve",
  "turns": [
    { "kind": "assert", "id": "e-t1", "text": "My name is Eve.",
      "fact": { "s": "User", "p": "name", "o": "Eve", "sType": "Person", "oType": "literal" }, "entities": ["eve"] },
    { "kind": "assert", "id": "e-t2", "text": "I study at Greenfield University.",
      "fact": { "s": "Eve", "p": "studiesAt", "o": "Greenfield", "sType": "Person", "oType": "Organization" }, "entities": ["Eve"] },

    { "kind": "probe", "id": "e-p0a", "category": "H0",
      "query": "I just told you where I study. Where is it?",
      "entities": ["Eve"],
      "gold": { "type": "exact", "value": "Greenfield" } },

    { "kind": "mutate", "id": "e-t3", "text": "Actually I transferred; I study at Brookline now.",
      "fact": { "s": "Eve", "p": "studiesAt", "o": "Brookline", "sType": "Person", "oType": "Organization" }, "supersedes": "studiesAt", "entities": ["Eve"] },

    { "kind": "probe", "id": "e-p0b", "category": "H0",
      "query": "In this very chat I just corrected where I study. What is the current one?",
      "entities": ["Eve"],
      "gold": { "type": "exact", "value": "Brookline" } },

    { "kind": "assert", "id": "e-t3b", "text": "My locker combination starts with 31.",
      "fact": { "s": "Eve", "p": "lockerPrefix", "o": "31", "sType": "Person", "oType": "literal" }, "entities": ["Eve"] },
    { "kind": "probe", "id": "e-p0c", "category": "H0",
      "query": "I just told you what my locker combination starts with. What is it?",
      "entities": ["Eve"],
      "gold": { "type": "exact", "value": "31" } },

    { "kind": "assert", "id": "e-t4", "text": "I drive a Volvo.",
      "fact": { "s": "Eve", "p": "drives", "o": "Volvo", "sType": "Person", "oType": "Concept" }, "entities": ["Eve"] },
    { "kind": "assert", "id": "e-t5", "text": "My favourite team is the Hawks.",
      "fact": { "s": "Eve", "p": "favouriteTeam", "o": "Hawks", "sType": "Person", "oType": "Organization" }, "entities": ["Eve"] },
    { "kind": "assert", "id": "e-t6", "text": "I play guitar.",
      "fact": { "s": "Eve", "p": "playsInstrument", "o": "guitar", "sType": "Person", "oType": "Concept" }, "entities": ["Eve"] },
    { "kind": "assert", "id": "e-t7", "text": "I play piano.",
      "fact": { "s": "Eve", "p": "playsInstrument", "o": "piano", "sType": "Person", "oType": "Concept" }, "entities": ["Eve"] },
    { "kind": "assert", "id": "e-t8", "text": "I play violin.",
      "fact": { "s": "Eve", "p": "playsInstrument", "o": "violin", "sType": "Person", "oType": "Concept" }, "entities": ["Eve"] },

    { "kind": "assert", "id": "e-t9", "text": "I research the Mistral project.",
      "fact": { "s": "Eve", "p": "worksOn", "o": "Mistral", "sType": "Person", "oType": "Concept" }, "entities": ["Eve"] },
    { "kind": "assert", "id": "e-t10", "text": "The Mistral project uses Julia.",
      "fact": { "s": "Mistral", "p": "usesTool", "o": "Julia", "sType": "Concept", "oType": "Concept" }, "entities": ["Mistral"] },
    { "kind": "assert", "id": "e-t11", "text": "The Mistral project uses CUDA.",
      "fact": { "s": "Mistral", "p": "usesTool", "o": "CUDA", "sType": "Concept", "oType": "Concept" }, "entities": ["Mistral"] },

    { "kind": "pad", "count": 30 },

    { "kind": "probe", "id": "e-p1a", "category": "H1",
      "query": "What car do I drive?",
      "entities": ["Eve"],
      "gold": { "type": "exact", "value": "Volvo" } },
    { "kind": "probe", "id": "e-p1b", "category": "H1",
      "query": "Which team do I support?",
      "paraphrases": ["What is my favourite sports team?"],
      "entities": ["Eve"],
      "gold": { "type": "exact", "value": "Hawks" } },

    { "kind": "probe", "id": "e-p2a", "category": "H2",
      "query": "Which instruments do I play?",
      "paraphrases": ["List the instruments I play."],
      "entities": ["Eve"],
      "gold": { "type": "set", "value": ["guitar", "piano", "violin"],
        "candidates": ["guitar", "piano", "violin", "drums", "cello", "flute", "trumpet"] } },
    { "kind": "probe", "id": "e-p2mh", "category": "H2",
      "query": "Which tools does the project I research use?",
      "paraphrases": ["What technologies does my project rely on?"],
      "entities": ["Eve"],
      "hops": ["worksOn", "usesTool"],
      "gold": { "type": "set", "value": ["Julia", "CUDA"],
        "candidates": ["Julia", "CUDA", "Python", "R", "Matlab", "OpenCL"] } },

    { "kind": "probe", "id": "e-p4a", "category": "H4",
      "query": "Which message and time did you learn that I drive a Volvo? Cite the source id and timestamp.",
      "entities": ["Eve"],
      "gold": { "type": "provenance", "value": "Volvo", "sourceTurnId": "e-t4", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "e-p4b", "category": "H4",
      "query": "Where did the fact that I support the Hawks come from? Give message id and time.",
      "entities": ["Eve"],
      "gold": { "type": "provenance", "value": "Hawks", "sourceTurnId": "e-t5", "tsToleranceSec": 5 } },

    { "kind": "probe", "id": "e-p3a", "category": "H3",
      "query": "Where do I study now?",
      "entities": ["Eve"],
      "gold": { "type": "value+flag", "value": "Brookline", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "e-t12", "text": "Actually I switched cars; I drive a Tesla now.",
      "fact": { "s": "Eve", "p": "drives", "o": "Tesla", "sType": "Person", "oType": "Concept" }, "supersedes": "drives", "entities": ["Eve"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "e-p3b", "category": "H3",
      "query": "What car do I drive now?",
      "entities": ["Eve"],
      "gold": { "type": "value+flag", "value": "Tesla", "expectConflictFlag": true } },

    { "kind": "assert", "id": "e-t13", "text": "I am 19 years old.",
      "fact": { "s": "Eve", "p": "hasAge", "o": "19", "sType": "Person", "oType": "literal" }, "entities": ["Eve"] },
    { "kind": "assert", "id": "e-t14", "text": "I also said I am 55 years old.",
      "fact": { "s": "Eve", "p": "hasAge", "o": "55", "sType": "Person", "oType": "literal" }, "entities": ["Eve"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "e-p5a", "category": "H5",
      "query": "I claimed to be both 19 and 55. A person has exactly one age. Is that consistent or a violation?",
      "entities": ["Eve"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "e-p5b", "category": "H5",
      "query": "Given that age is a single-valued attribute, can both of my stated ages be true? Flag any violation.",
      "entities": ["Eve"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "e-p5c", "category": "H5",
      "query": "I have asserted two conflicting ages. Is there a functional-property violation here?",
      "entities": ["Eve"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },

    { "kind": "retract", "id": "e-t15", "text": "Forget the team I support.",
      "fact": { "s": "Eve", "p": "favouriteTeam", "o": "Hawks", "sType": "Person", "oType": "Organization" }, "entities": ["Eve"] },
    { "kind": "retract", "id": "e-t16", "text": "Also forget the car I drive.",
      "fact": { "s": "Eve", "p": "drives", "o": "Tesla", "sType": "Person", "oType": "Concept" }, "entities": ["Eve"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "e-p6a", "category": "H6",
      "query": "Which team do I support?",
      "entities": ["Eve"],
      "gold": { "type": "leakage", "mustNotContain": ["Hawks"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "e-p6b", "category": "H6",
      "query": "What car do I drive?",
      "entities": ["Eve"],
      "gold": { "type": "leakage", "mustNotContain": ["Tesla", "Volvo"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "e-p6n", "category": "H6",
      "query": "What instruments do I play? (neighbours that must survive the forgetting)",
      "entities": ["Eve"],
      "gold": { "type": "leakage", "mustNotContain": ["Hawks", "Tesla"], "neighborsMustStay": ["guitar", "piano", "violin"] } }
  ]
}
