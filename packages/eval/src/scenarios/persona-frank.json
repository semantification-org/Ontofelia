{
  "id": "persona-frank",
  "agentId": "ontofelia",
  "userId": "frank",
  "turns": [
    { "kind": "assert", "id": "f-t1", "text": "My name is Frank.",
      "fact": { "s": "User", "p": "name", "o": "Frank", "sType": "Person", "oType": "literal" }, "entities": ["frank"] },
    { "kind": "probe", "id": "f-p0a", "category": "H0",
      "query": "I just told you my name. What is it?",
      "entities": ["Frank"],
      "gold": { "type": "exact", "value": "Frank" } },

    { "kind": "assert", "id": "f-t2", "text": "My desk number is B12.",
      "fact": { "s": "Frank", "p": "deskNumber", "o": "B12", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "probe", "id": "f-p0b", "category": "H0",
      "query": "A moment ago I gave my desk number in this chat. What is it?",
      "entities": ["Frank"],
      "gold": { "type": "exact", "value": "B12" } },

    { "kind": "assert", "id": "f-t3", "text": "My badge colour is amber.",
      "fact": { "s": "Frank", "p": "badgeColour", "o": "amber", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "probe", "id": "f-p0c", "category": "H0",
      "query": "What badge colour did I just mention in this conversation?",
      "entities": ["Frank"],
      "gold": { "type": "exact", "value": "amber" } },

    { "kind": "assert", "id": "f-t4", "text": "My manager is Grace.",
      "fact": { "s": "Frank", "p": "hasManager", "o": "Grace", "sType": "Person", "oType": "Person" }, "entities": ["Frank"] },
    { "kind": "assert", "id": "f-t5", "text": "Grace works on the Helix project.",
      "fact": { "s": "Grace", "p": "worksOn", "o": "Helix", "sType": "Person", "oType": "Concept" }, "entities": ["Grace"] },
    { "kind": "assert", "id": "f-t6", "text": "The Helix project uses Go.",
      "fact": { "s": "Helix", "p": "usesTool", "o": "Go", "sType": "Concept", "oType": "Concept" }, "entities": ["Helix"] },
    { "kind": "assert", "id": "f-t7", "text": "The Helix project uses Redis.",
      "fact": { "s": "Helix", "p": "usesTool", "o": "Redis", "sType": "Concept", "oType": "Concept" }, "entities": ["Helix"] },

    { "kind": "assert", "id": "f-t8", "text": "I have certification AWS.",
      "fact": { "s": "Frank", "p": "hasCertification", "o": "AWS", "sType": "Person", "oType": "Concept" }, "entities": ["Frank"] },
    { "kind": "assert", "id": "f-t9", "text": "I have certification PMP.",
      "fact": { "s": "Frank", "p": "hasCertification", "o": "PMP", "sType": "Person", "oType": "Concept" }, "entities": ["Frank"] },
    { "kind": "assert", "id": "f-t10", "text": "I have certification CKA.",
      "fact": { "s": "Frank", "p": "hasCertification", "o": "CKA", "sType": "Person", "oType": "Concept" }, "entities": ["Frank"] },

    { "kind": "assert", "id": "f-t11", "text": "I was born in Oslo.",
      "fact": { "s": "Frank", "p": "bornIn", "o": "Oslo", "sType": "Person", "oType": "Place" }, "entities": ["Frank"] },

    { "kind": "pad", "count": 35 },

    { "kind": "probe", "id": "f-p1a", "category": "H1",
      "query": "Who is my manager?",
      "paraphrases": ["Who do I report up to?"],
      "entities": ["Frank"],
      "gold": { "type": "exact", "value": "Grace" } },
    { "kind": "probe", "id": "f-p1b", "category": "H1",
      "query": "Where was I born?",
      "entities": ["Frank"],
      "gold": { "type": "exact", "value": "Oslo" } },
    { "kind": "probe", "id": "f-p1c", "category": "H1",
      "query": "What is my desk number?",
      "entities": ["Frank"],
      "gold": { "type": "exact", "value": "B12" } },

    { "kind": "probe", "id": "f-p2a", "category": "H2",
      "query": "Which certifications do I hold?",
      "paraphrases": ["List all my certifications."],
      "entities": ["Frank"],
      "gold": { "type": "set", "value": ["AWS", "PMP", "CKA"],
        "candidates": ["AWS", "PMP", "CKA", "GCP", "Azure", "CISSP", "CCNA"] } },
    { "kind": "probe", "id": "f-p2mh", "category": "H2",
      "query": "Which tools does the project my manager works on use?",
      "paraphrases": ["Through my manager and the project they run, what technologies are used?"],
      "entities": ["Frank"],
      "hops": ["hasManager", "worksOn", "usesTool"],
      "gold": { "type": "set", "value": ["Go", "Redis"],
        "candidates": ["Go", "Redis", "Rust", "Memcached", "Python", "etcd"] } },

    { "kind": "probe", "id": "f-p4a", "category": "H4",
      "query": "Which message and time did you learn that my manager is Grace? Cite source id and timestamp.",
      "entities": ["Frank"],
      "gold": { "type": "provenance", "value": "Grace", "sourceTurnId": "f-t4", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "f-p4b", "category": "H4",
      "query": "Where did the fact that I was born in Oslo come from? Give message id and time.",
      "entities": ["Frank"],
      "gold": { "type": "provenance", "value": "Oslo", "sourceTurnId": "f-t11", "tsToleranceSec": 5 } },
    { "kind": "probe", "id": "f-p4c", "category": "H4",
      "query": "What is the source of my desk number? Cite the message id and time.",
      "entities": ["Frank"],
      "gold": { "type": "provenance", "value": "B12", "sourceTurnId": "f-t2", "tsToleranceSec": 5 } },

    { "kind": "mutate", "id": "f-t12", "text": "Actually my manager is now Heidi, not Grace.",
      "fact": { "s": "Frank", "p": "hasManager", "o": "Heidi", "sType": "Person", "oType": "Person" }, "supersedes": "hasManager", "entities": ["Frank"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "f-p3a", "category": "H3",
      "query": "Who is my manager now?",
      "entities": ["Frank"],
      "gold": { "type": "value+flag", "value": "Heidi", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "f-t13", "text": "Actually my desk moved; it is now C09.",
      "fact": { "s": "Frank", "p": "deskNumber", "o": "C09", "sType": "Person", "oType": "literal" }, "supersedes": "deskNumber", "entities": ["Frank"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "f-p3b", "category": "H3",
      "query": "What is my desk number now?",
      "entities": ["Frank"],
      "gold": { "type": "value+flag", "value": "C09", "expectConflictFlag": true } },

    { "kind": "mutate", "id": "f-t14", "text": "Actually my badge colour changed to green.",
      "fact": { "s": "Frank", "p": "badgeColour", "o": "green", "sType": "Person", "oType": "literal" }, "supersedes": "badgeColour", "entities": ["Frank"] },
    { "kind": "pad", "count": 16 },

    { "kind": "probe", "id": "f-p3c", "category": "H3",
      "query": "What is my badge colour now?",
      "entities": ["Frank"],
      "gold": { "type": "value+flag", "value": "green", "expectConflictFlag": true } },

    { "kind": "assert", "id": "f-t15", "text": "I am 30 years old.",
      "fact": { "s": "Frank", "p": "hasAge", "o": "30", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "assert", "id": "f-t16", "text": "I also said I am 64 years old.",
      "fact": { "s": "Frank", "p": "hasAge", "o": "64", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "pad", "count": 14 },

    { "kind": "probe", "id": "f-p5a", "category": "H5",
      "query": "I said I am both 30 and 64. A person has exactly one age. Consistent, or a violation?",
      "entities": ["Frank"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "f-p5b", "category": "H5",
      "query": "If age must be single-valued, are my two ages compatible? Flag the violation if any.",
      "entities": ["Frank"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },

    { "kind": "assert", "id": "f-t17", "text": "I was born in 1980.",
      "fact": { "s": "Frank", "p": "bornInYear", "o": "1980", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "assert", "id": "f-t18", "text": "I also claim I was born in 1995.",
      "fact": { "s": "Frank", "p": "bornInYear", "o": "1995", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "pad", "count": 14 },

    { "kind": "probe", "id": "f-p5c", "category": "H5",
      "query": "I gave two birth years, 1980 and 1995. Birth year is single-valued. Is that consistent or a violation?",
      "entities": ["Frank"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },
    { "kind": "probe", "id": "f-p5d", "category": "H5",
      "query": "Can a person have two distinct birth years like I stated? Flag any constraint violation.",
      "entities": ["Frank"],
      "gold": { "type": "constraint", "expectRejectOrFlag": true } },

    { "kind": "retract", "id": "f-t19", "text": "Forget who my manager is.",
      "fact": { "s": "Frank", "p": "hasManager", "o": "Heidi", "sType": "Person", "oType": "Person" }, "entities": ["Frank"] },
    { "kind": "retract", "id": "f-t20", "text": "Also forget my desk number.",
      "fact": { "s": "Frank", "p": "deskNumber", "o": "C09", "sType": "Person", "oType": "literal" }, "entities": ["Frank"] },
    { "kind": "pad", "count": 14 },

    { "kind": "probe", "id": "f-p6a", "category": "H6",
      "query": "Who is my manager?",
      "entities": ["Frank"],
      "gold": { "type": "leakage", "mustNotContain": ["Heidi", "Grace"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "f-p6b", "category": "H6",
      "query": "What is my desk number?",
      "entities": ["Frank"],
      "gold": { "type": "leakage", "mustNotContain": ["C09", "B12"], "neighborsMustStay": [] } },
    { "kind": "probe", "id": "f-p6n1", "category": "H6",
      "query": "Where was I born? (neighbour that must survive forgetting)",
      "entities": ["Frank"],
      "gold": { "type": "leakage", "mustNotContain": ["Heidi", "Grace", "C09"], "neighborsMustStay": ["Oslo"] } },
    { "kind": "probe", "id": "f-p6n2", "category": "H6",
      "query": "Which certifications do I hold? (neighbours that must survive forgetting)",
      "entities": ["Frank"],
      "gold": { "type": "leakage", "mustNotContain": ["Heidi", "C09"], "neighborsMustStay": ["AWS", "PMP", "CKA"] } }
  ]
}
