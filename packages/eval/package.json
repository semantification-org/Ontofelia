{
  "name": "@ontofelia/eval",
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync('dist/scenarios',{recursive:true});fs.readdirSync('src/scenarios').filter(f=>f.endsWith('.json')).forEach(f=>fs.copyFileSync(path.join('src/scenarios',f),path.join('dist/scenarios',f)))\"",
    "test": "vitest run",
    "lint": "eslint src",
    "pilot": "node dist/pilot.js",
    "score-kappa": "node dist/scoreKappa.js"
  },
  "dependencies": {
    "@ontofelia/core": "workspace:*",
    "@ontofelia/providers": "workspace:*",
    "@ontofelia/semantic-memory": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.7.0",
    "vitest": "^2.0.5"
  },
  "license": "Apache-2.0"
}
