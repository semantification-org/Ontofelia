# ─────────────────────────────────────────────────────────────
# Ontofelia — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# The onboarding wizard (`ontofelia onboard`) writes most settings to
# ~/.ontofelia/ontofelia.json5 — you only need .env for overrides or
# CI/deployment scenarios.
# ─────────────────────────────────────────────────────────────

# LLM provider API key.
# The primary place for this is the `provider.apiKey` field inside
# ~/.ontofelia/ontofelia.json5 (created by `ontofelia onboard`).
# Setting it here overrides the config file value.
OPENROUTER_API_KEY=

# Alternative: OpenAI-compatible API key
# OPENAI_API_KEY=

# Gateway bind address (default: 127.0.0.1)
# ONTOFELIA_HOST=127.0.0.1

# Gateway port (default: 18780)
# ONTOFELIA_PORT=18780

# Log level: fatal | error | warn | info | debug | trace
# ONTOFELIA_LOG_LEVEL=info
